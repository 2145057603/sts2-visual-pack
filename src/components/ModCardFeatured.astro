---
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_LABELS } from '../data/categories';

interface Props {
  mod: CollectionEntry<'mods'>;
}

const { mod } = Astro.props;
const { title, cover, description, category, tags, downloadUrl, author } = mod.data;
const categoryName = CATEGORY_LABELS[category] ?? category;
---

<div class="mod-card group flex flex-col md:flex-row overflow-hidden">
  <!-- 封面图 -->
  <a href={`/mods/${mod.slug}/`} class="md:w-64 lg:w-80 shrink-0">
    <div class="aspect-video md:aspect-auto md:h-full min-h-40 overflow-hidden bg-surface-700">
      {cover ? (
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center text-6xl text-surface-500">
          🗡️
        </div>
      )}
    </div>
  </a>

  <!-- 内容 -->
  <div class="flex-1 p-6 flex flex-col justify-between">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="badge-accent text-xs">{categoryName}</span>
        <span class="text-xs text-gray-500">by {author}</span>
      </div>

      <a href={`/mods/${mod.slug}/`}>
        <h3 class="font-bold text-xl text-gray-100 mb-3 group-hover:text-primary-400 transition-colors leading-snug">
          {title}
        </h3>
      </a>

      <p class="text-gray-400 text-sm leading-relaxed line-clamp-3 mb-4">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-4">
          {tags.map((tag) => (
            <span class="text-xs text-gray-400 bg-surface-700 border border-surface-500 px-2.5 py-0.5 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <div class="flex items-center gap-3 flex-wrap">
      <a href={downloadUrl} target="_blank" rel="noopener noreferrer" class="btn-download text-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
        </svg>
        立即下载
      </a>
      <a href={`/mods/${mod.slug}/`} class="btn-secondary text-sm">
        查看详情 →
      </a>
    </div>
  </div>
</div>
